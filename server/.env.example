# ============================================================
# SERVER ENVIRONMENT CONFIGURATION
# DO NOT COMMIT THIS FILE - ALREADY IN .gitignore
# ============================================================

# ============================================================
# MONGODB ATLAS DATABASE
# ============================================================
# IMPORTANT: Rotate your MongoDB password immediately!
# GitHub detected exposed credentials. Follow these steps:
# 
# 1. Go to: https://cloud.mongodb.com/v2/YOUR_ORG_ID#/org/users
# 2. Click "Database Access" 
# 3. Delete the exposed database user
# 4. Create a NEW user with a strong password
# 5. Copy the new connection string below
# 
# Connection String Format:
# mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# 
MONGODB_URI=mongodb+srv://YOUR_NEW_USERNAME:YOUR_NEW_PASSWORD@ecosnap.0cte9yh.mongodb.net/ecosnap?retryWrites=true&w=majority

# ============================================================
# SERVER PORT
# ============================================================
PORT=5000

# ============================================================
# ENVIRONMENT
# ============================================================
NODE_ENV=development

# ============================================================
# JWT & AUTHENTICATION
# ============================================================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ============================================================
# GOOGLE OAUTH 2.0
# ============================================================
# Get credentials from: https://console.cloud.google.com/
# Steps:
# 1. Create OAuth 2.0 Credentials (Web Application)
# 2. Add "http://localhost:5173" as authorized JavaScript origin
# 3. Copy the Client ID below
# 
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# ============================================================
# EMAIL VERIFICATION (Gmail SMTP)
# ============================================================
# NOTE: Use Gmail App Passwords, NOT your regular password!
# Steps to get App Password:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password below
# 
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_16_chars
