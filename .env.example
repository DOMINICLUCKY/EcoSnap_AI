# ============================================================
# ENVIRONMENT CONFIGURATION
# DO NOT COMMIT THIS FILE - ADD TO .gitignore
# ============================================================

# ============================================================
# MONGODB ATLAS DATABASE
# ============================================================
# 1. Go to MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# 2. Create a cluster named "ecosnap"
# 3. Create a database user with strong password
# 4. Copy the connection string and replace placeholder below
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/ecosnap?retryWrites=true&w=majority

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5000
NODE_ENV=development

# ============================================================
# SUPABASE CONFIGURATION (Optional - for real-time features)
# ============================================================
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# NEWS API CONFIGURATION (Optional - for news features)
# ============================================================
VITE_NEWS_API_KEY=your_news_api_key_here
